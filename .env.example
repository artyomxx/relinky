# Copy to .env and fill in values:  cp .env.example .env
# .env is gitignored — do not commit real secrets.

# -----------------------------------------------------------------------------
# Required: admin login — sha512-crypt ($6$), not the plain password
# Generate:  npm run hash-password -- 'your-password'
# Or:        openssl passwd -6 'your-password'
# Optional:  ADMIN_PASSWORD_SHA512_ROUNDS (default 5000) for hash-password script
#
# MUST be single-quoted — Docker Compose env_file still interpolates unquoted $ and
# breaks sha512-crypt strings (login always 401). Example:
#   ADMIN_PASSWORD_HASH='$6$rounds=5000$saltstring$hashhere...'
# If you ever use ${ADMIN_PASSWORD_HASH} in YAML instead, escape every $ as $$.
#
# Coolify / hosts that mangle $: use ADMIN_PASSWORD_HASH_B64 (base64 of the utf8 $6$ line).
# Generate:  npm run hash-password -- 'your-password' --b64
# -----------------------------------------------------------------------------
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD_HASH_B64=

# Optional: set to 1 / true / yes to log failed logins (reason, IP, password field missing|empty|non-empty, UA snippet).
# Never logs the password. Turn off after debugging.
# ADMIN_LOGIN_DEBUG=1

# -----------------------------------------------------------------------------
# Optional: bind addresses (default docker-compose: 0.0.0.0; gateway image forces 127.0.0.1)
# -----------------------------------------------------------------------------
# ADMIN_IP=0.0.0.0
# ADMIN_PORT=8081
# REDIRECTOR_IP=0.0.0.0
# REDIRECTOR_PORT=8082

# -----------------------------------------------------------------------------
# Coolify: use docker-compose.coolify.yml (two services: admin 8081 + redirector 8082).
# -----------------------------------------------------------------------------
# Gateway mode: use docker-compose.gateway.yml (Caddy on 80/443; RELINKY_USE_GATEWAY is set there)
# -----------------------------------------------------------------------------

# Hostname for the admin UI (DNS must point at this server)
RELINKY_ADMIN_HOST=admin.example.com

# Let’s Encrypt contact email (recommended when RELINKY_HTTP_ONLY is not set)
ACME_EMAIL=you@example.com

# Set to 1 for HTTP only on port 80 (local/LAN testing, no certificates)
RELINKY_HTTP_ONLY=0

# Gateway only: Caddy listen ports inside the container (default 80 / 443 if unset)
# RELINKY_CADDY_HTTP_PORT=9080
# RELINKY_CADDY_HTTPS_PORT=8443

# Gateway only: host ports Docker publishes (default 80 / 443). Example: use 9080 on host → 9080 in container
# RELINKY_GATEWAY_HOST_HTTP=9080
# RELINKY_GATEWAY_HOST_HTTPS=8443

# Gateway HTTPS without public 80/443 for Let’s Encrypt: self-signed Caddy certs (browser warning; fine for testing)
# RELINKY_CADDY_TLS_INTERNAL=1

# Set to 1 to use Let’s Encrypt staging (avoid rate limits while testing)
RELINKY_ACME_STAGING=0

# Override generated Caddyfile path (default: /app/caddy/Caddyfile in the container)
# CADDYFILE_PATH=
